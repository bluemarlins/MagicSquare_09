################################################################################
# project
################################################################################
project:
  name: "MagicSquare"
  description: "4×4 마방진 두 빈칸 채우기 — Dual-Track TDD + Clean Architecture 훈련 프로젝트"
  language: "Python"
  python_version: "3.10+"
  paradigm: "ECB (Entity-Control-Boundary) + TDD"
  domain_constants:
    magic_constant: 34
    grid_size: 4
    blank_marker: 0
    blank_count: 2
    value_range: "1~16"
    coordinate_system: "1-index (행·열 모두 1~4)"
  output_contract: "[r1, c1, n1, r2, c2, n2]  # int[6], 1-index 좌표, n1≠n2"
  invariants:
    - "INV-01: 모든 행·열·대각선 합 = 34"
    - "INV-02: 1~16 각각 정확히 1회 등장"
    - "INV-03: 격자 크기 = 4×4"
    - "INV-04: 빈칸(0) 개수 = 정확히 2"
    - "INV-05: 셀 값 ∈ {0, 1, …, 16}"
    - "INV-06: 0 제외 중복 없음"
    - "INV-07: 유효 조합 = 정확히 1가지"
    - "INV-08: 출력 좌표 r, c ∈ {1, 2, 3, 4}"
    - "INV-09: 출력 숫자 n1, n2 ∈ {1,…,16}, n1 ≠ n2"

################################################################################
# code_style
################################################################################
code_style:
  python_version: "3.10+"
  style_guide: "PEP8 엄격 준수"
  formatter: "Black (max_line_length: 88)"
  max_line_length: 88
  type_hints:
    required: true
    scope: "모든 함수 파라미터와 반환값에 필수"
    example: "def find_blanks(grid: list[list[int]]) -> list[tuple[int, int]]:"
  docstring:
    style: "Google 스타일"
    scope: "모든 public 메서드에 필수"
    example: |
      def solve(self, grid: list[list[int]]) -> list[int]:
          """두 빈칸을 채워 마방진을 완성하고 결과를 반환한다.

          Args:
              grid: 4×4 정수 행렬. 빈칸은 0으로 표기.

          Returns:
              [r1, c1, n1, r2, c2, n2] 형식의 정수 리스트 (1-index).

          Raises:
              NoSolutionError: 유효한 조합이 없을 때.
          """
  naming:
    classes: "PascalCase"
    functions_methods: "snake_case"
    constants: "UPPER_SNAKE_CASE"
    private: "_single_leading_underscore"
    test_functions: "test_ 접두사 필수"
  imports:
    order: "stdlib → third-party → local (isort 기준)"
    wildcard: "금지 (from module import * 사용 금지)"

################################################################################
# architecture
################################################################################
architecture:
  pattern: "ECB (Entity-Control-Boundary)"
  dependency_direction: "Boundary → Control → Entity  (역방향 절대 금지)"

  boundary:
    role: "외부 입출력 담당 — 호출자와의 계약 이행"
    responsibilities:
      - "4단계 입력 검증 (크기 → 값 범위 → 빈칸 수 → 중복)"
      - "Domain 예외를 표준 ErrorResponse로 변환"
      - "첫 번째 실패 즉시 반환 (다중 오류 동시 반환 금지)"
    components: ["InputValidator", "ResponseFormatter", "MagicSquareController"]
    error_codes:
      - "INVALID_INPUT"
      - "INVALID_GRID_SIZE"
      - "INVALID_BLANK_COUNT"
      - "INVALID_CELL_VALUE"
      - "DUPLICATE_VALUE"
      - "NO_SOLUTION"
      - "INTERNAL_ERROR"
    must_not:
      - "Domain 객체를 직접 생성하거나 로직을 수행"
      - "Data Layer를 직접 호출"

  control:
    role: "비즈니스 로직 담당 — Domain 서비스 조율"
    responsibilities:
      - "BlankFinder → MissingNumberFinder → SolvingStrategy 순서 조율"
      - "Domain 예외를 그대로 전파 (변환하지 않음)"
      - "선택적 Application Facade 역할 수행"
    components: ["MagicSquareSolver"]
    must_not:
      - "입력 유효성 검증 수행 (Boundary 책임)"
      - "저장/로드 직접 수행 (Data Layer 책임)"

  entity:
    role: "도메인 데이터 및 규칙 담당 — 순수 로직, 외부 의존 없음"
    responsibilities:
      - "도메인 불변조건(INV-01~INV-09) 자가 검증"
      - "Value Object 불변성 보장"
      - "마방진 수학적 검증 (합산 조건 10개)"
    components:
      entities: ["MagicSquare"]
      value_objects: ["Cell", "CellValue", "MissingPair", "SolveResult"]
      domain_services: ["BlankFinder", "MissingNumberFinder", "MagicSquareValidator"]
    must_not:
      - "저장소(Repository) 의존"
      - "UI·입출력 관련 코드 포함"
      - "외부 라이브러리 의존 (순수 Python만 허용)"

  forbidden_dependencies:
    - "Entity → Control  (절대 금지)"
    - "Entity → Boundary (절대 금지)"
    - "Control → Boundary (절대 금지)"
    - "Boundary → Data 직접 호출 (Facade 경유 필수)"

################################################################################
# tdd_rules
################################################################################
tdd_rules:
  cycle: "RED → GREEN → REFACTOR  (순서 생략 또는 역전 금지)"

  red_phase:
    description: "테스트를 먼저 작성하고 반드시 실패(RED) 상태를 확인한 뒤 구현 단계로 진행한다."
    rules:
      - "테스트 코드는 구현 코드보다 반드시 먼저 존재해야 한다."
      - "새 테스트는 컴파일 오류 또는 AssertionError로 RED 상태여야 한다."
      - "테스트 ID(BF-T01 등)와 보호 불변조건(INV-01~INV-09)을 주석으로 명시한다."
      - "하나씩 사이클을 완료한다 — GREEN 없이 RED→RED 연속 추가 금지."
    must_not:
      - "테스트를 작성하기 전에 구현 코드를 먼저 작성하는 것"
      - "RED 확인 없이 GREEN 단계로 넘어가는 것"
      - "여러 테스트를 한꺼번에 추가한 뒤 한 번에 통과시키는 것"

  green_phase:
    description: "테스트를 통과시키는 최소한의 코드만 작성한다."
    rules:
      - "테스트를 통과시키기 위한 최소 코드만 추가한다."
      - "하드코딩도 허용 — 일반화는 REFACTOR 단계에서 한다."
      - "기존 GREEN 테스트를 깨뜨리는 코드 작성 금지."
    must_not:
      - "이 단계에서 리팩터링·추상화·구조 개선을 수행하는 것"
      - "네이밍 변경, 메서드 추출, 클래스 분리 등 구조적 작업"
      - "아직 RED 상태인 다른 테스트를 동시에 통과시키려는 것"

  refactor_phase:
    description: "기능을 변경하지 않고 구조를 개선한다. 커버리지는 리팩터링 전후 동일 수준을 유지한다."
    rules:
      - "모든 테스트가 GREEN인 상태에서만 리팩터링을 시작한다."
      - "리팩터링 중 테스트 로직을 수정하지 않는다 — 테스트가 깨지면 즉시 되돌린다."
      - "커버리지 목표 유지: Domain ≥ 95% / UI Boundary ≥ 85% / Data Layer ≥ 80%."
      - "리팩터링 후 전체 테스트 재실행으로 회귀(regression) 없음을 검증한다."
    must_not:
      - "리팩터링 중 새 기능을 추가하는 것"
      - "테스트가 RED인 상태에서 리팩터링을 시작하는 것"
      - "커버리지 목표치 이하로 떨어뜨리는 것"

################################################################################
# testing
################################################################################
testing:
  framework: "pytest"
  pattern: "AAA (Arrange-Act-Assert)"
  coverage_minimum:
    domain_layer: "95%"
    ui_boundary: "85%"
    data_layer: "80%"
  total_test_cases: 74
  test_distribution:
    - "Domain — BlankFinder:        BF-T01~T06  (6개)"
    - "Domain — MissingNumberFinder: MF-T01~T05  (5개)"
    - "Domain — MagicSquareValidator: MV-T01~T07 (7개)"
    - "Domain — SolvingStrategy:     SS-T01~T05  (5개)"
    - "Domain — SolveResult VO:      SR-T01~T06  (6개)"
    - "Control — MagicSquareSolver:  SV-T01~T03  (3개)"
    - "UI Boundary:                  UI-T01~T19  (19개)"
    - "Data Layer:                   DT-T01~T13  (13개)"
    - "Integration (정상):           IT-S01~S04  (4개)"
    - "Integration (실패):           IT-F01~F06  (6개)"
  naming_convention:
    test_files: "test_<module_name>.py"
    test_functions: "test_<scenario_description>  # test_ 접두사 필수"
    test_classes: "Test<TargetClass>"
    example: "def test_blank_finder_returns_two_cells_in_row_major_order():"
  fixture_scope:
    function: "기본값 — 각 테스트마다 새 인스턴스 생성 (격리 보장)"
    class: "동일 클래스 내 상태 공유가 명확히 필요한 경우만"
    module: "사용 금지 — 테스트 간 상태 오염 위험"
    session: "사용 금지 — 전체 테스트 결합도 증가"
  mocking:
    rule: "UI Boundary 테스트에서 Domain은 반드시 Mock으로 대체"
    library: "pytest-mock 또는 unittest.mock"
    must_not: "실제 Domain 로직에 의존하는 UI 테스트 작성"
  assertion:
    - "단일 테스트에 검증 포인트는 1~3개 이내로 제한"
    - "예외 검증은 pytest.raises() 사용 필수"
    - "부동소수점 비교 금지 — 이 프로젝트는 정수 연산만 사용"

################################################################################
# forbidden
################################################################################
forbidden:
  - pattern: "print() 직접 사용 (테스트 코드 포함)"
    reason: "디버그 출력이 테스트 결과를 오염시키고 로그 추적을 불가능하게 함"
    alternative: "logging 모듈 사용 또는 pytest의 capsys fixture 활용"

  - pattern: "하드코딩 상수 (매직 넘버) — REFACTOR 단계 이후"
    reason: "도메인 상수(34, 4, 16 등)가 여러 곳에 분산되면 변경 시 일관성 깨짐"
    alternative: "project.domain_constants 또는 별도 constants.py에 선언 후 참조"
    exception: "GREEN 단계에서는 최소 구현을 위해 일시적 하드코딩 허용"

  - pattern: "except 단독 사용 (bare except)"
    reason: "KeyboardInterrupt·SystemExit 등 치명적 예외까지 무시하여 디버깅 불가"
    alternative: "except Exception as e: 또는 구체적 예외 타입 명시"

  - pattern: "Domain → Boundary / Domain → Data 방향 import"
    reason: "ECB 의존성 방향(Boundary→Control→Entity) 위반 — 아키텍처 붕괴"
    alternative: "의존성 역전(DI)으로 인터페이스에만 의존"

  - pattern: "isinstance() 로 레이어 간 타입 분기"
    reason: "레이어 경계를 우회하는 암묵적 결합 — 다형성 원칙 위반"
    alternative: "추상 메서드 오버라이드 또는 Protocol 사용"

  - pattern: "테스트 파일에서 실제 파일 I/O 또는 네트워크 호출"
    reason: "테스트 격리 원칙 위반 — 외부 상태에 의존하면 재현성 없음"
    alternative: "InMemoryRepository 또는 pytest fixtures로 대체"

  - pattern: "type: ignore 주석 남용"
    reason: "타입힌트 강제 규칙을 우회하여 타입 안전성 훼손"
    alternative: "올바른 타입 선언 또는 Union/Optional 활용"

################################################################################
# file_structure
################################################################################
file_structure:
  # ECB 기준 패키지 구조 (트리)
  #
  # magic_square/                   ← 프로젝트 루트
  # ├── .cursorrules
  # ├── pyproject.toml              ← Black / isort / pytest 설정 통합
  # ├── requirements.txt
  # │
  # ├── boundary/                   ← Boundary Layer (외부 입출력)
  # │   ├── __init__.py
  # │   ├── input_validator.py      ← 4단계 입력 검증
  # │   ├── response_formatter.py   ← 정상 응답 / 에러 응답 포맷
  # │   └── magic_square_controller.py  ← 진입점 (Facade 역할)
  # │
  # ├── control/                    ← Control Layer (비즈니스 흐름 조율)
  # │   ├── __init__.py
  # │   └── magic_square_solver.py  ← BlankFinder→MissingFinder→Strategy 조율
  # │
  # ├── entity/                     ← Entity Layer (도메인 순수 로직)
  # │   ├── __init__.py
  # │   ├── magic_square.py         ← 핵심 엔티티 (4×4 격자)
  # │   ├── value_objects/
  # │   │   ├── __init__.py
  # │   │   ├── cell.py             ← (row, col) 불변 VO
  # │   │   ├── cell_value.py       ← 0 또는 1~16 불변 VO
  # │   │   ├── missing_pair.py     ← (smaller, larger) 불변 VO
  # │   │   └── solve_result.py     ← int[6] 래퍼 불변 VO
  # │   └── services/
  # │       ├── __init__.py
  # │       ├── blank_finder.py
  # │       ├── missing_number_finder.py
  # │       ├── magic_square_validator.py
  # │       └── solving_strategy.py
  # │
  # ├── data/                       ← Data Layer (저장소 추상화)
  # │   ├── __init__.py
  # │   ├── matrix_repository.py    ← 저장소 인터페이스 (Protocol)
  # │   └── in_memory_repository.py ← 기본 구현체
  # │
  # ├── exceptions/                 ← 예외 정의 (레이어별 분리)
  # │   ├── __init__.py
  # │   ├── domain_exceptions.py    ← MagicSquareError (base)
  # │   │                               NoSolutionError        (INV-07)
  # │   │                               InvalidBlankCountError (INV-04)
  # │   │                               InvalidMissingCountError (INV-02)
  # │   │                               IncompleteGridError    (INV-01)
  # │   ├── data_exceptions.py      ← DataLayerError (base)
  # │   │                               DuplicateIdError
  # │   │                               NotFoundError
  # │   └── boundary_exceptions.py  ← 에러코드 7종 상수
  # │                                   SuccessResponse (TypedDict)
  # │                                   ErrorResponse   (TypedDict)
  # │
  # └── tests/                      ← 전체 테스트 (74개)
  #     ├── __init__.py
  #     ├── conftest.py             ← 공통 fixture 정의
  #     ├── entity/
  #     │   ├── test_blank_finder.py         ← BF-T01~T06
  #     │   ├── test_missing_number_finder.py ← MF-T01~T05
  #     │   ├── test_magic_square_validator.py ← MV-T01~T07
  #     │   ├── test_solving_strategy.py      ← SS-T01~T05
  #     │   └── test_solve_result.py          ← SR-T01~T06
  #     ├── boundary/
  #     │   └── test_input_validator.py       ← UI-T01~T19
  #     ├── control/
  #     │   └── test_magic_square_solver.py   ← SV-T01~T03
  #     ├── data/
  #     │   └── test_in_memory_repository.py  ← DT-T01~T13
  #     └── integration/
  #         └── test_integration.py           ← IT-S01~S04, IT-F01~F06
  root: "magic_square/"
  layers:
    - "boundary/"
    - "control/"
    - "entity/"
    - "data/"
    - "exceptions/"
    - "tests/"
    - "tests/entity/"
    - "tests/control/"
    - "tests/boundary/"
    - "tests/data/"
    - "tests/integration/"

################################################################################
# ai_behavior
################################################################################
ai_behavior:
  before_writing_code:
    - rule: "관련 테스트 파일을 먼저 확인한다."
      detail: "구현 파일을 작성하기 전에 tests/ 하위의 대응 테스트 파일을 Read 도구로 열어 계약을 파악한다."
    - rule: "현재 TDD 단계(RED / GREEN / REFACTOR)를 파악한다."
      detail: "사용자가 단계를 명시하지 않으면 '현재 어느 단계인지' 반드시 확인 후 진행한다."
    - rule: "변경하려는 파일의 ECB 레이어를 식별한다."
      detail: "boundary / control / entity / data 중 어느 레이어인지 확인하고 의존성 방향 위반 여부를 검토한다."

  while_writing_code:
    - rule: "ECB 레이어 경계 위반 금지."
      detail: "Entity가 Boundary를 import하거나, Control이 Boundary에 의존하는 코드를 생성하지 않는다."
    - rule: "타입힌트 없는 함수 생성 금지."
      detail: "모든 파라미터와 반환값에 타입힌트를 명시한다. 타입힌트 없는 함수는 생성하지 않는다."
    - rule: "Google 스타일 docstring 없는 public 메서드 생성 금지."
      detail: "_로 시작하지 않는 모든 메서드에 Args / Returns / Raises 섹션을 포함한 docstring을 작성한다."
    - rule: "tdd_rules 위반 감지 시 경고를 출력한다."
      detail: |
        아래 상황 중 하나가 감지되면 코드 생성 전에 경고 메시지를 출력한다:
        - GREEN 단계에서 리팩터링 요청
        - 테스트 없이 구현 코드 작성 요청
        - RED 확인 없이 다음 단계 진행 요청
        경고 형식: "[TDD 경고] {위반 내용}. tdd_rules.{phase}.must_not 참조."

  after_writing_code:
    - rule: "생성한 코드의 테스트 ID 추적 가능성을 확인한다."
      detail: "구현 코드에 대응하는 테스트 ID(예: BF-T01)와 보호 불변조건(예: INV-04)이 주석에 명시되어 있는지 확인한다."
    - rule: "forbidden 항목 위반 여부를 자가 검토한다."
      detail: "print(), bare except, 레이어 역방향 import, 타입힌트 누락 중 하나라도 발견되면 즉시 수정안을 제시한다."
    - rule: "응답 언어는 항상 한국어를 사용한다."
      detail: "코드 내 주석·docstring은 한국어로, 변수·함수명은 영어(snake_case)로 작성한다."
